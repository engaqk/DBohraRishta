rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: authenticated users can read all, write only their own
    // Admin access is enforced at the application layer (admin_auth_token)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Rishta Requests: allow all authenticated users to read/list
    // Real security: only admin portal (token-protected page) can list all
    match /rishta_requests/{requestId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null;

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // OTP usage tracker
    match /sys_otp_usage/{dateId} {
      allow read, write: if request.auth != null;
    }

    // Admin <-> User messaging threads
    // collectionGroup query for admin dashboard message counters
    match /{path=**}/thread/{msgId} {
      allow read, write: if request.auth != null;
    }

    match /admin_messages/{userId} {
      allow read, write: if request.auth != null;
      match /thread/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Official announcements
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Audit logs for admin actions
    match /admin_audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Bookmarks / Saved Profiles
    match /bookmarks/{bookmarkId} {
      allow read, write: if request.auth != null;
    }

    // Profile Views / Visitors
    match /profile_views/{viewId} {
      allow read, write: if request.auth != null;
    }
  }
}
