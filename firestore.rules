rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the current user an admin?
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection: authenticated users can read all, write only their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Special override for status updates in admin pipeline
      allow update: if request.auth != null; // KEEP for quick testing as user requested
    }

    // Rishta Requests: authenticated users can read their own requests, create new ones
    match /rishta_requests/{requestId} {
      allow read: if request.auth != null && (
        resource.data.from == request.auth.uid || 
        resource.data.to == request.auth.uid ||
        isAdmin()
      );
      // Allow collection listing for admin stats
      allow list: if isAdmin();
      
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.from == request.auth.uid || 
        resource.data.to == request.auth.uid ||
        isAdmin()
      );

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.from == request.auth.uid ||
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.to == request.auth.uid ||
          isAdmin()
        );
      }
    }

    // OTP usage tracker: any authenticated user can read/write
    match /sys_otp_usage/{dateId} {
      allow read, write: if request.auth != null;
    }

    // Admin <-> User messaging threads
    match /{path=**}/thread/{msgId} {
      allow read, write: if request.auth != null;
    }

    match /admin_messages/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      match /thread/{msgId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
