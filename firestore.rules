rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: authenticated users can read/write their own profiles
    match /users/{userId} {
      allow read, write: if request.auth != null;

      // Notifications subcollection
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rishta Requests: allow authenticated users to interact with requests
    match /rishta_requests/{requestId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // Chat messages subcollection inside requests
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // OTP usage tracker (standard verification)
    match /sys_otp_usage/{dateId} {
      allow read, write: if request.auth != null;
    }

    // Admin <-> User messaging threads
    match /{path=**}/thread/{msgId} {
      allow read, write: if request.auth != null;
    }

    match /admin_messages/{userId} {
      allow read, write: if request.auth != null;
      match /thread/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Official announcements
    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Audit logs for admin actions
    match /admin_audit_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Bookmarks / Saved Profiles
    match /bookmarks/{bookmarkId} {
      allow read, write: if request.auth != null;
    }

    // Profile Views / Visitors
    match /profile_views/{viewId} {
      allow read, write: if request.auth != null;
    }
  }
}
