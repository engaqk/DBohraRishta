rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      );
    }
    
    // Users collection: authenticated users can read all, write own OR admin
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && (isOwner(userId) || isAdmin());

      // Notifications: Only owner/admin reads
      match /notifications/{notifId} {
        allow read, update, delete: if signedIn() && (isOwner(userId) || isAdmin());
        allow create: if signedIn();
      }
    }

    // Rishta Requests: Only involved parties can read/update
    match /rishta_requests/{requestId} {
      allow read: if signedIn(); // Optimization: Allow list for dashboard, but filtered by query
      allow create: if signedIn();
      allow update: if signedIn() && (
        resource.data.from == request.auth.uid || 
        resource.data.to == request.auth.uid
      );

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    // OTP tracking
    match /sys_otp_usage/{dateId} {
      allow read, write: if signedIn();
    }

    // Admin Messages & Support Threads
    match /admin_messages/{userId} {
      allow read, write: if signedIn() && (isOwner(userId) || request.auth.token.admin == true);
      
      match /thread/{msgId} {
        allow read, write: if signedIn();
      }
    }

    // Collection group support for support threads
    match /{path=**}/thread/{msgId} {
      allow read, write: if signedIn();
    }

    // Official announcements: All read, Admin write
    match /broadcasts/{broadcastId} {
      allow read: if signedIn();
      allow write: if signedIn(); // Temporary allow until admin claims are set up
    }

    // Audit logs
    match /admin_audit_logs/{logId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // SMS Broadcasts (admin only, via textbee)
    match /sms_broadcasts/{broadcastId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // Bookmarks: Private to user
    match /bookmarks/{bookmarkId} {
      allow read, write: if signedIn() && (
        request.method == 'create' || 
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.query.limit <= 100) // Allow reading if it's the user's filtered query
      );
    }

    // Unblur Requests: Involved parties
    match /unblur_requests/{requestId} {
      allow read, create, update, delete: if signedIn();
    }

    // Profile Views: Logged for profile owner
    match /profile_views/{viewId} {
      allow read, write: if signedIn();
    }
  }
}
