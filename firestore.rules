rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true || 
        request.auth.uid == 'admin-panel-service-account' ||       
        request.auth.token.email == '53dbohrarishta@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }
    
    // Users collection: get is public, list/write restricted
    match /users/{userId} {
      allow get: if true;
      allow list: if signedIn();
      allow create: if signedIn() && isOwner(userId) && 
        !(request.resource.data.get('status', '') in ['verified', 'approved', 'archived', 'premium']) &&
        request.resource.data.get('isPhotoVerified', false) == false &&
        request.resource.data.get('isItsVerified', false) == false;

      allow update: if signedIn() && (
        isAdmin() || 
        (isOwner(userId) && (
          // 1. Photo Identity: Must be same as before OR set to false
          (request.resource.data.get('isPhotoVerified', false) == resource.data.get('isPhotoVerified', false) || 
           request.resource.data.get('isPhotoVerified', false) == false) &&

          // 2. ITS Verification: Must be same as before OR set to false
          (request.resource.data.get('isItsVerified', false) == resource.data.get('isItsVerified', false) ||
           request.resource.data.get('isItsVerified', false) == false) &&

          // 3. Profile Status: Must be same as before OR set to a non-privileged status
          (request.resource.data.get('status', '') == resource.data.get('status', '') ||
           !(request.resource.data.get('status', '') in ['verified', 'approved', 'archived', 'premium'])) &&

          // 4. Selfie Review Status: Must be same as before OR set to a non-authoritative status
          (request.resource.data.get('selfieStatus', '') == resource.data.get('selfieStatus', '') ||
           request.resource.data.get('selfieStatus', '') in ['', 'pending', 'rejected'])
        ))
      );
      allow delete: if isAdmin(); // Deletions allowed for system integrity checks by Admin

      // Notifications: Only owner/admin reads
      match /notifications/{notifId} {
        allow read, update, delete: if signedIn() && (isOwner(userId) || isAdmin());
        allow create: if signedIn();
      }
    }

    // Rishta Requests: Protected list/get
    match /rishta_requests/{requestId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      );
      allow create, update: if signedIn();

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read, write: if signedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.from == request.auth.uid ||
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.to == request.auth.uid
        );
      }
    }

    // OTP tracking
    match /sys_otp_usage/{dateId} {
      allow read, write: if signedIn();
    }

    // Admin Messages & Support Threads
    match /admin_messages/{userId} {
      allow read, write: if signedIn() && (isOwner(userId) || isAdmin());
      
      match /thread/{msgId} {
        allow read, write: if signedIn() && (isOwner(userId) || isAdmin());
      }
    }

    // Official announcements: All read, Admin write
    match /broadcasts/{broadcastId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Audit logs: Admin only
    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // SMS Broadcasts: Admin only
    match /sms_broadcasts/{broadcastId} {
      allow read: if isAdmin();
      allow write: if false; // Strictly via Server SDK
    }

    // SMS delivery logs: Admin only
    match /sms_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Strictly via Server SDK
    }

    // Bookmarks: Private to user OR Admin
    match /bookmarks/{bookmarkId} {
      allow read, write: if signedIn() && (
        isAdmin() ||
        request.method == 'create' || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // Unblur Requests: Involved parties
    match /unblur_requests/{requestId} {
      allow read, create, update, delete: if signedIn();
    }

    // Profile Views: Owner or Admin
    match /profile_views/{viewId} {
      allow read, write: if signedIn() && (
        isAdmin() ||
        request.method == 'create' ||
        (resource != null && resource.data.profileId == request.auth.uid)
      );
    }
  }
}
