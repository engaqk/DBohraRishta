rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function signedIn() {
      return request.auth != null
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true || 
        request.auth.token.email == '53dbohrarishta@gmail.com' ||
        request.auth.uid == 'admin-panel-service-account' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      )
    }

    // --- 🛡️ Contact Leakage Prevention Helper ---
    function isClean(val) {
      // Very simple string check to avoid rule crashes
      return val == null || string(val).size() < 5 || (
        !(string(val).toLower().matches('.*@.*')) && 
        !(string(val).toLower().matches('.*[0-9]{12,}.*'))
      )
    }
    
    // Users collection: get is public, list/write restricted
    match /users/{userId} {
      allow get, list: if true
      allow create: if signedIn() && (isOwner(userId) || isAdmin())

      allow update: if signedIn() && (
        isAdmin() || 
        (isOwner(userId) && (
          // Protect verified fields
          request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
          (request.resource.data.get('status', '') == resource.data.get('status', '') || !(request.resource.data.get('status', '') in ['verified', 'approved', 'archived', 'premium'])) &&
          (request.resource.data.get('isItsVerified', false) == resource.data.get('isItsVerified', false) || request.resource.data.get('isItsVerified', false) == false) &&
          (resource.data.get('isItsVerified', false) == false || request.resource.data.get('itsNumber', '') == resource.data.get('itsNumber', ''))
        )) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCount', 'interestsCount', 'viewsCount', 'isOnline', 'lastActive']))
      )
      allow delete: if isAdmin()

      // Notifications: Only owner/admin reads
      match /notifications/{notifId} {
        allow read, update, delete: if signedIn() && (isOwner(userId) || isAdmin())
        allow create: if signedIn()
      }
    }

    // Rishta Requests: Protected list/get
    match /rishta_requests/{requestId} {
      allow read: if signedIn() && (
        isAdmin() ||
        resource.data.from == request.auth.uid ||
        resource.data.to == request.auth.uid
      )
      allow create: if signedIn() && 
        request.resource.data.from == request.auth.uid &&
        isClean(request.resource.data.get('icebreaker', ''))
      allow update: if signedIn() && (
        isAdmin() ||
        (resource.data.from == request.auth.uid && (
            // Sender can ONLY update to 'withdrawn' or same status
            request.resource.data.get('from', '') == resource.data.get('from', '') &&
            request.resource.data.get('to', '') == resource.data.get('to', '') &&
            request.resource.data.status in [resource.data.status, 'withdrawn']
        )) ||
        (resource.data.to == request.auth.uid && (
            // Receiver can ONLY update to 'accepted' or 'declined' or 'read'
            request.resource.data.get('from', '') == resource.data.get('from', '') &&
            request.resource.data.get('to', '') == resource.data.get('to', '') &&
            request.resource.data.status in ['accepted', 'declined', 'read', resource.data.status]
        ))
      )
      allow delete: if isAdmin()

      // Chat messages subcollection
      match /messages/{messageId} {
        allow read, write: if signedIn() && (
          isAdmin() ||
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.from == request.auth.uid ||
          get(/databases/$(database)/documents/rishta_requests/$(requestId)).data.to == request.auth.uid
        )
      }
    }

    // OTP tracking
    match /sys_otp_usage/{dateId} {
      allow read, write: if signedIn()
    }

    // Admin Messages & Support Threads
    match /admin_messages/{userId} {
      allow read, write: if signedIn() && (isOwner(userId) || isAdmin())
      
      match /thread/{msgId} {
        allow read, write: if signedIn() && (isOwner(userId) || isAdmin())
      }
    }

    // Official announcements: All read, Admin write
    match /broadcasts/{broadcastId} {
      allow read: if signedIn()
      allow write: if isAdmin()
    }

    // Audit logs: Admin only
    match /admin_audit_logs/{logId} {
      allow read, write: if isAdmin()
    }

    // SMS Broadcasts: Admin only
    match /sms_broadcasts/{broadcastId} {
      allow read: if isAdmin()
      allow write: if false // Strictly via Server SDK
    }

    // SMS delivery logs: Admin only
    match /sms_logs/{logId} {
      allow read: if isAdmin()
      allow write: if false // Strictly via Server SDK
    }

    // Bookmarks: Private to user OR Admin
    match /bookmarks/{bookmarkId} {
      allow read, delete: if signedIn() && (isAdmin() || resource.data.userId == request.auth.uid)
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid
    }

    // Unblur Requests: Involved parties
    match /unblur_requests/{requestId} {
      allow read: if signedIn() && (isAdmin() || resource.data.from == request.auth.uid || resource.data.to == request.auth.uid)
      allow create: if signedIn() && request.resource.data.from == request.auth.uid
      allow update: if signedIn() && (
        isAdmin() ||
        (resource.data.from == request.auth.uid && (
            // Sender can only change status to 'withdrawn' from current
            request.resource.data.status in [resource.data.status, 'withdrawn']
        )) ||
        (resource.data.to == request.auth.uid && (
            // Receiver can only accept/decline
            request.resource.data.status in ['accepted', 'declined', resource.data.status]
        ))
      )
      allow delete: if isAdmin()
    }

    // Profile Views: Owner or Admin
    match /profile_views/{viewId} {
      allow read: if signedIn() && (isAdmin() || resource.data.profileId == request.auth.uid)
      allow create: if signedIn() && (isAdmin() || request.resource.data.viewerId == request.auth.uid)
    }
  }
}
